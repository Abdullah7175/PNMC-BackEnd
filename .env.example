DATABASE_URL=postgresql://root:password@localhost:5432/PNMC?sslmode=disable
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001
UPLOAD_DIR=./uploads
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000
NODE_ENV=development
ENABLE_SWAGGER=true
